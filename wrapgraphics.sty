%[doc]
% \texttt{wrapgraphics.sty} --- the \LaTeX{} package file.
%
% This file provides the user-facing \verb|\wrapgraphics| command.
% It defines package options and macro keys, saves the image in a box,
% shell-escapes to Python for contour tracing, and delegates the
% \verb|\parshape| computation to Lua.
%
% \subsection*{Package structure}
% The package follows the \textsf{minted} pattern:
% \begin{itemize}
%   \item \texttt{wrapgraphics.sty} --- here: option/keys/box/\verb|\directlua|
%   \item \texttt{wrapgraphics.lua} --- SVG parsing, parshape computation
%   \item \texttt{wrapgraphics.py} --- alpha threshold, contour tracing
% \end{itemize}
%
% \subsection*{Required packages}
% The package loads \textsf{luatexbase} (for Lua callbacks),
% \textsf{graphicx} (for \verb|\includegraphics|),
% \textsf{xkeyval} (for key--value option parsing),
% and \textsf{xcolor} (for contour colour).
%[/doc]
\ProvidesPackage{wrapgraphics}[2024-01-01 v0.2 Wrap text around image alpha contour]
\RequirePackage{luatexbase}
\RequirePackage{graphicx}
\RequirePackage{xkeyval}
\RequirePackage{xcolor}

%[doc]
% \subsection*{Default values and package options}
% Internal macros store the default values for every key.
% Two package options are recognised:
% \verb|verbose| enables diagnostic output;
% \verb|contour| sets the default contour colour.
%[/doc]
\def\wr@threshold{0.5}
\def\wr@padding{5}
\def\wr@smooth{0}
\def\wr@scale{1}
\def\wr@position{left}
\def\wr@width{}
\def\wr@hang{false}
\def\wr@lines{}
\def\wr@skip{0}
\def\wr@shiftx{0pt}
\def\wr@shifty{0pt}
\def\wr@anchor{here}
\def\wr@verbose{false}
\DeclareOptionX{verbose}{\def\wr@verbose{true}}
\def\wr@contour@false{false}
\def\wr@contour@default{false}
\DeclareOptionX{contour}[red]{\def\wr@contour@default{#1}}
\ProcessOptionsX\relax

%[doc]
% \subsection*{Macro keys}
% All keys use the \texttt{wr} family (\textsf{xkeyval} syntax).
% Most are stored as plain macros; \texttt{width} and
% \texttt{shift\_x}/\texttt{shift\_y} evaluate \LaTeX{} lengths
% so that units like \texttt{cm} or \texttt{pt} are properly parsed.
% A positive \texttt{shift\_y} moves the image down (into the
% wrapping paragraph); a negative \texttt{shift\_y} moves it up,
% overlaying the text of the preceding paragraph (the wrapping
% shape only affects lines from the \texttt{\string\wrapgraphics}
% command onward).
% The \texttt{contour} key accepts any \textsf{xcolor} name and
% maps \texttt{true} to red as a shortcut.
%[/doc]
\newdimen\wr@tmpdimen
\define@key{wr}{threshold}{\def\wr@threshold{#1}}
\define@key{wr}{padding}{\def\wr@padding{#1}}
\define@key{wr}{smooth}{\def\wr@smooth{#1}}
\define@key{wr}{scale}{\def\wr@scale{#1}}
\define@key{wr}{position}{\def\wr@position{#1}}
\define@key{wr}{width}{%
  \setlength{\wr@tmpdimen}{#1}%
  \edef\wr@width{\the\wr@tmpdimen}%
}
\define@key{wr}{hang}{\def\wr@hang{#1}}
\define@key{wr}{lines}{\def\wr@lines{#1}}
\define@key{wr}{skip}{\def\wr@skip{#1}}
\define@key{wr}{shift_x}{%
  \setlength{\wr@tmpdimen}{#1}%
  \edef\wr@shiftx{\the\wr@tmpdimen}%
}
\define@key{wr}{shift_y}{%
  \setlength{\wr@tmpdimen}{#1}%
  \edef\wr@shifty{\the\wr@tmpdimen}%
}
\define@key{wr}{anchor}{\def\wr@anchor{#1}}
\define@key{wr}{contour}{%
  \def\wr@contour{#1}%
  \if\wr@contour true\def\wr@contour{red}\fi
}

%[doc]
% \subsection*{Image box and Lua module}
% The image is saved in \verb|\wr@imagebox| so that its dimensions
% are available when the paragraph reflows.
%
% The Lua module \texttt{wrapgraphics.lua} is loaded via
% \verb|\directlua| using \verb|kpse.find_file| for path resolution
% (following the \textsf{minted} approach).  A separate \texttt{.lua}
% file avoids TeX catcode issues with \verb|#| and \verb|~| inside
% \verb|\directlua|.
%[/doc]
\newsavebox{\wr@imagebox}

\directlua{local f=kpse.find_file("wrapgraphics.lua","lua");if f then dofile(f)else dofile("wrapgraphics.lua")end}

%[doc]
% \subsection*{\texttt{\string\wrapgraphics}}
% The user-facing command.  Its first argument is a comma-separated
% list of key--value options; the second is the image file path.
%
% \begin{enumerate}
%   \item Keys from the first argument override the defaults via
%         \verb|\setkeys{wr}|.
%   \item The image is saved in \verb|\wr@imagebox| with the requested
%         \texttt{scale} or \texttt{width}.
%   \item The box is lowered to its own height so the reference point
%         sits at the bottom-left corner.
%   \item A contour colour is set up if requested.
%   \item Lua is called via \verb|\directlua|: all parameters are
%         written to \texttt{tex.*} globals and
%         \texttt{wrapgraphics\_run()} is invoked.
% \end{enumerate}
%[/doc]
\newcommand{\wrapgraphics}[2][]{%
  \let\wr@contour\wr@contour@default
  \setkeys{wr}{#1}%
  \def\wr@filepath{#2}%
  %
  \savebox{\wr@imagebox}{%
    \ifx\wr@width\empty
      \includegraphics[scale=\wr@scale]{\wr@filepath}%
    \else
      \includegraphics[width=\wr@width]{\wr@filepath}%
    \fi
  }%
  \setbox\wr@imagebox=\hbox{\lower\ht\wr@imagebox\box\wr@imagebox}%
  %
  \ifx\wr@contour\wr@contour@false\else
    \colorlet{wr@tmpcolor}{\wr@contour}%
  \fi
  %
  \directlua{%
    tex.wr_filepath = "\luaescapestring{\wr@filepath}"
    tex.wr_threshold = "\wr@threshold"
    tex.wr_padding = "\wr@padding"
    tex.wr_smooth = "\wr@smooth"
    tex.wr_scale = "\wr@scale"
    tex.wr_position = "\wr@position"
    tex.wr_width = "\wr@width"
    tex.wr_hang = "\wr@hang"
    tex.wr_lines = "\wr@lines"
    tex.wr_skip = "\wr@skip"
    tex.wr_verbose = "\wr@verbose"
    tex.wr_contour = "\wr@contour"
    tex.wr_shiftx = "\wr@shiftx"
    tex.wr_shifty = "\wr@shifty"
    tex.wr_anchor = "\wr@anchor"
    tex.wr_columnsep = "\the\columnsep"
    tex.wr_twocolumn = "\if@twocolumn true\else false\fi"
    wrapgraphics_run()
  }%
  \ignorespaces
}

% Ensure parshape is updated after every paragraph, even when
% \subsection* or other commands reset \everypar via \@afterheading.
\AddToHook{para/begin}{\directlua{wr_setup_parshape()}}

\endinput
